meta {
  name: Get Offers
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/api/v3/offers?lang={{lang}}
  body: text
  auth: none
}

params:query {
  lang: {{lang}}
}

headers {
  X-Token: {{API_TOKEN}}
  Token-Type: {{TOKEN_TYPE}}
