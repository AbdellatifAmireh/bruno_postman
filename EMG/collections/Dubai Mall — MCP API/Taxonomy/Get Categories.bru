meta {
  name: Get Categories
  type: http
  seq: 2
}

get {
  url: {{API_URL}}/api/v1/categories?extends=categories,subCategories&lang={{lang}}
  body: none
  auth: none
}

params:query {
  extends: categories,subCategories
  lang: {{lang}}
}

headers {
  X-Token: {{API_TOKEN}}
  Token-Type: {{TOKEN_TYPE}}
  Accept: application/json
}

docs {
  getCategories
}
