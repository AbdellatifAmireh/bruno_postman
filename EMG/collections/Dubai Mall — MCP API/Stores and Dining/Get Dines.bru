meta {
  name: Get Dines
  type: http
  seq: 3
}

get {
  url: {{API_URL}}/api/v1/dines?extends=categories,subCategories,tags,location&lang={{lang}}
  body: none
  auth: none
}

params:query {
  extends: categories,subCategories,tags,location
  lang: {{lang}}
}

headers {
  X-Token: {{API_TOKEN}}
  Token-Type: {{TOKEN_TYPE}}
  Accept: application/json
}

docs {
  getDines
}
